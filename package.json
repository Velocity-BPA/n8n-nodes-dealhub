{
  "name": "@velocity-bpa/n8n-nodes-dealhub",
  "version": "1.0.0",
  "description": "n8n community node for DealHub - Manages deals, quotes, proposals, and buyer engagement",
  "license": "bsl-catalog",
  "homepage": "https://www.velocity-bpa.com/n8n-nodes-dealhub",
  "author": {
    "name": "Velocity BPA",
    "email": "info@velocity-bpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/velocity-bpa/n8n-nodes-dealhub.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/DealHubApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/DealHub/DealHub.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.15.1",
    "@typescript-eslint/parser": "^7.15.1",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "n8n-workflow": "*",
    "prettier": "^3.3.2",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "axios": "^1.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "dealhub",
    "deals",
    "quotes",
    "proposals",
    "sales",
    "crm"
  ]
}