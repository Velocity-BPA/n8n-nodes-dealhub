{
  "name": "@velocity-bpa/n8n-nodes-dealhub",
  "version": "1.0.0",
  "description": "n8n community node for DealHub",
  "license": "SEE LICENSE IN LICENSE.md",
  "main": "dist/nodes/DealHub/DealHub.node.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "files": [
    "dist/**/*"
  ],
  "keywords": [
    "n8n-community-node-package",
    "n8n-node",
    "dealhub",
    "quotes",
    "dealrooms",
    "crm"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/DealHubApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/DealHub/DealHub.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "format": "prettier nodes credentials --write",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "n8n-workflow": "*"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/velocity-bpa/n8n-nodes-dealhub.git"
  },
  "author": {
    "name": "Velocity BPA",
    "url": "https://velocity-bpa.com"
  }
}